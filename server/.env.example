# CapitalGrid Backend - Environment Configuration Template

# Server Listening Port (Render dynamically assigns this, defaults to 5000)
PORT=5000

# MongoDB Connection URI (e.g. local mongodb, or MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://your_db_username:your_db_password@cluster0.mongodb.net/capitalgrid?retryWrites=true&w=majority

# JWT Token Secret (Choose a cryptographically strong random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Google OAuth Client ID for social login integration
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
